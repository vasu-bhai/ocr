# DocExtract Environment Configuration
# Copy to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./docextract.db

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# ── OCR Engine (PaddleOCR) ────────────────────────────────────────────────────
OCR_GPU=false                      # Set to true if CUDA GPU is available

# ── LLM Extraction Engine (Groq) ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Extraction Settings ───────────────────────────────────────────────────────
CONFIDENCE_REVIEW_THRESHOLD=0.85   # Flag for human review below this
MAX_FILE_SIZE_MB=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/docextract.log
